PUT https://t9-store-project.onrender.com/reviews/65f1a2b3c4d5e6f7a8b9c0d1 HTTP/1.1
Content-Type: application/json

{
    "productId": "65f1a2b3c4d5e6f7a8b9c0d1",
    "userId": "user_rudy_99",
    "rating": 4,
    "comment": "Actually, the battery life could be slightly better.",

### --- LOCALHOST TESTS (STUDENTS) ---

### GET ALL STUDENTS
GET http://localhost:8080/students

### GET STUDENT BY ID
# Replace the ID below with a real ID from the MongoDB Compass
GET http://localhost:8080/students/65f1a2b3c4d5e6f7a8b9c0d1

### CREATE STUDENT
POST http://localhost:8080/students HTTP/1.1
Content-Type: application/json

{
    "firstName": "Rudy",
    "lastName": "Pilande",
    "email": "rpilande@byupathway.edu",
    "age": 23,
    "major": "Software Development",
    "gpa": 3.8,
    "admissionDate": "2023-09-01",
    "totalCredits": 96
}

### UPDATE STUDENT
# Replace the ID below with the ID returned from the POST request above
PUT http://localhost:8080/students/65f1a2b3c4d5e6f7a8b9c0d1 HTTP/1.1
Content-Type: application/json

{
    "firstName": "Rudy",
    "lastName": "Pilande",
    "email": "rpilande@newmail.edu",
    "age": 24,
    "major": "Software Engineering",
    "gpa": 4.0,
    "admissionDate": "2023-09-01",
    "totalCredits": 102
}

### DELETE STUDENT
DELETE http://localhost:8080/students/65f1a2b3c4d5e6f7a8b9c0d1 HTTP/1.1


